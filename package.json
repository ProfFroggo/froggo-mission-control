    "googleapis": "^171.4.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.303.0",
    "mermaid": "^11.14.0",
    "next": "^16.1.6",
    "node-gyp": "^12.2.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-grid-layout": "^2.2.2",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.2",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.4",
