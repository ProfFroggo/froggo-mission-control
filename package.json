{
  "name": "froggo-mission-control",
  "version": "2.0.0",
  "description": "Self-hosted AI agent platform for Claude Code CLI. Multi-agent orchestration, task management, Gmail, Calendar, Kanban and more.",
  "keywords": [
    "claude",
    "ai-agents",
    "claude-code",
    "mission-control",
    "mcp",
    "multi-agent"
  ],
  "homepage": "https://github.com/ProfFroggo/froggo-mission-control",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProfFroggo/froggo-mission-control.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mission-control": "bin/cli.js"
  },
  "files": [
    "app/",
    "src/",
    "!src/tests/",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/",
    "public/",
    "catalog/",
    ".claude/CLAUDE.md",
    ".claude/settings.json.template",
    ".claude/agents/",
    ".claude/skills/",
    "bin/",
    "scripts/",
    "tools/mission-control-db-mcp/src/",
    "!tools/**/*.test.ts",
    "tools/mission-control-db-mcp/package.json",
    "tools/mission-control-db-mcp/tsconfig.json",
    "tools/memory-mcp/src/",
    "tools/memory-mcp/package.json",
    "tools/memory-mcp/tsconfig.json",
    "tools/cron-mcp/src/",
    "tools/cron-mcp/package.json",
    "tools/cron-mcp/tsconfig.json",
    "tools/hooks/",
    "tools/cron-daemon.js",
    "tools/session-monitor.js",
    "tools/e2e-smoke-test.sh",
    "tools/db/*.sql",
    "next.config.js",
    "tsconfig.json",
    "tailwind.config.js",
    "postcss.config.mjs",
    ".env.example",
    ".mcp.json.example",
    "APPROVAL_RULES.md",
    "README.md",
    "ecosystem.config.js",
    "install.sh",
    "templates/"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "next dev",
    "build": "NODE_ENV=production TURBOPACK= NEXT_BUILD=1 next build --webpack",
    "build:verify": "NODE_ENV=production NEXT_BUILD_OUTPUT=.next-verify TURBOPACK= NEXT_BUILD=1 next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@assistant-ui/react": "^0.12.20",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@elevenlabs/client": "^1.1.1",
