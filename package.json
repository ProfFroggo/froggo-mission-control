{
  "name": "clawd-dashboard",
  "version": "0.1.0",
  "description": "Clawdbot Dashboard - Agent Management & Task Tracking",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json && cp electron/agent-registry.json dist-electron/agent-registry.json",
    "electron:dev": "npm run electron:compile && ./start.sh",
    "deploy": "bash deploy.sh",
    "electron:build": "npm run electron:compile && vite build && electron-builder",
    "start": "./start.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/react-grid-layout": "^1.3.6",
    "@types/recharts": "^1.8.29",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-grid-layout": "^2.2.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "better-sqlite3": "^12.6.2",
    "sqlite3": "^5.1.7",
    "vosk-browser": "^0.0.8",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.4.0",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.clawdbot.froggo",
    "productName": "Froggo",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": false,
    "extraResources": [
      {
        "from": "public/models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": "build/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Froggo uses your microphone for voice commands and meeting transcription.",
        "NSCameraUsageDescription": "Froggo uses your camera for video chat and visual context during voice conversations.",
        "NSSpeechRecognitionUsageDescription": "Froggo uses speech recognition for voice commands."
      }
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
