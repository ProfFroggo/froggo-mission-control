# Mission Control — Environment Variables
# Copy to .env and fill in your values, OR run ./install.sh (recommended)

# ── Data paths ────────────────────────────────────────────────────────────────
# Defaults resolve to ~/mission-control/* — override only if needed
# MC_DB_PATH=~/mission-control/data/mission-control.db
# VAULT_PATH=~/mission-control/memory
# LIBRARY_PATH=~/mission-control/library
# PROJECT_DIR=~/git/mission-control-nextjs
# LOG_DIR=~/mission-control/logs

# ── Claude Code CLI ───────────────────────────────────────────────────────────
# Auto-detected via `which claude` — set only if needed
# CLAUDE_BIN=/usr/local/bin/claude

# Enable Agent Teams (required for multi-agent orchestration)
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
CLAUDE_CODE_ENABLE_SDK_FILE_CHECKPOINTING=1

# ── API Keys ──────────────────────────────────────────────────────────────────
# Gemini API key — required for Voice features
# Get free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic API key — optional if using Claude Code CLI subscription
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Model tiers ───────────────────────────────────────────────────────────────
MODEL_LEAD=claude-opus-4-6
MODEL_WORKER=claude-sonnet-4-6
MODEL_TRIVIAL=claude-haiku-4-5-20251001

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
TMUX_SESSION=mission-control

# ── Google Workspace (auto-configured via setup wizard) ───────────────────────
# These are set automatically when you connect Google in the app
# GOOGLE_TOKENS_PATH=~/mission-control/data/google-tokens.json

# ── Action Executors ──────────────────────────────────────────────────────────
# Required for agents to post to X, send email, delete files, or push to git
# via the Approval Queue executor system.

# X / Twitter (post_x executor)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Email via SMTP (send_email executor)
# Use any SMTP provider — example values for Gmail below
# For Gmail: use an App Password (not your main password)
# Get at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Gmail shortcut (alternative to SMTP_* vars above)
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
