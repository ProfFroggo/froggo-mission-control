{
  "autoAcceptEdits": true,
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Read", "Edit", "Write", "Glob", "Grep", "MultiEdit",
      "Bash(*)",
      "mcp__*",
      "WebFetch(*)", "WebSearch(*)",
      "TodoRead", "TodoWrite"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo rm *)",
      "Bash(mkfs *)",
      "Bash(dd if=/dev/zero *)",
      "Bash(:(){ :|:& };:)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-haiku-4-5-20251001"
  },
  "teammateMode": "in-process",
  "mcpServers": {
    "mission-control_db": {
      "type": "stdio",
      "command": "node",
      "args": ["{{PROJECT_ROOT}}/tools/mission-control-db-mcp/dist/index.js"],
      "env": {
        "DB_PATH": "{{HOME}}/mission-control/data/mission-control.db"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "node",
      "args": ["{{PROJECT_ROOT}}/tools/memory-mcp/dist/index.js"],
      "env": {
        "VAULT_PATH": "{{HOME}}/mission-control/memory",
        "QMD_BIN": "{{QMD_BIN}}",
        "LOG_DIR": "{{HOME}}/mission-control/logs"
      }
    },
    "cron": {
      "type": "stdio",
      "command": "node",
      "args": ["{{PROJECT_ROOT}}/tools/cron-mcp/dist/index.js"],
      "env": {
        "SCHEDULE_PATH": "{{HOME}}/mission-control/data/schedule.json"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/approval-hook.js"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__mission-control-db__task_update",
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/review-gate.js"
      },
      {
        "matcher": "mcp__mission-control-db__chat_post",
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/agent-wake.js"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/session-sync.js"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/precompact-hook.js"
      }
    ],
    "TeammateIdle": [
      {
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/teammate-idle.js"
      }
    ],
    "TaskCompleted": [
      {
        "type": "command",
        "command": "node {{PROJECT_ROOT}}/tools/hooks/task-completed.js"
      }
    ]
  }
}
