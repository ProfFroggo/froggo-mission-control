{
  "id": "agent-mgmt",
  "name": "Agent Management",
  "version": "1.0.0",
  "description": "View and edit agent personalities, model configurations, and lifecycle state.",
  "author": "Mission Control Team",
  "icon": "Bot",
  "category": "agent",
  "core": true,
  "credentials": [],
  "views": [
    {
      "id": "agents",
      "label": "Agents",
      "icon": "Bot",
      "entrypoint": "./views/AgentPanel.tsx"
    }
  ],
  "ipcChannels": {
    "handle": [
      "agentManagement:soul:read",
      "agentManagement:soul:write",
      "agentManagement:models:read",
      "agentManagement:models:write",
      "agentManagement:ctx:check",
      "agentManagement:agent:start",
      "agentManagement:agent:stop",
      "agentManagement:agent:status"
    ]
  },
  "dependencies": {
    "core": ">=1.0.0",
    "modules": []
  },
  "permissions": {
    "ipc": [
      "agentManagement:*"
    ],
    "filesystem": [
      "$HOME/agent-*/SOUL.md",
      "$HOME/.mission-control/mission-control.json"
    ],
    "network": false,
    "shell": false
  }
}
