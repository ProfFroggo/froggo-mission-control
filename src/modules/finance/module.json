{
  "id": "froggo-finance",
  "name": "Finance",
  "version": "1.0.0",
  "description": "Multi-account financial management with AI-powered categorization, recurring detection, proactive insights, scenario projections, and XLSX export.",
  "author": "Froggo Team",
  "icon": "DollarSign",
  "category": "finance",

  "credentials": [
    {
      "id": "solana_rpc_url",
      "label": "Solana RPC URL",
      "description": "WebSocket endpoint for Solana network access",
      "required": false,
      "type": "url"
    }
  ],

  "healthCheck": {
    "type": "url",
    "credentialId": "solana_rpc_url",
    "method": "POST",
    "successStatus": 200
  },

  "views": [
    {
      "id": "finance",
      "label": "Finance",
      "icon": "DollarSign",
      "entrypoint": "./views/FinancePanel.tsx"
    }
  ],

  "ipcChannels": {
    "handle": [
      "finance:getTransactions",
      "finance:getBudgetStatus",
      "finance:selectFile",
      "finance:uploadCSV",
      "finance:uploadPDF",
      "finance:getAlerts",
      "finance:getInsights",
      "finance:dismissInsight",
      "finance:createBudget",
      "finance:triggerAnalysis",
      "finance:account:list",
      "finance:account:create",
      "finance:account:update",
      "finance:account:archive",
      "finance:account:balances",
      "finance:recurring:detect",
      "finance:recurring:list",
      "finance:recurring:confirm",
      "finance:recurring:dismiss",
      "finance:recurring:status",
      "finance:export:xlsx",
      "finance:category:list",
      "finance:category:getBreakdown",
      "finance:category:corrections",
      "finance:transaction:updateCategory",
      "finance:insights:generate",
      "finance:scenario:list",
      "finance:scenario:create",
      "finance:scenario:update",
      "finance:scenario:delete",
      "finance:scenario:project",
      "finance:scenario:projectSimple"
    ]
  },

  "dependencies": {
    "core": ">=1.0.0",
    "modules": []
  },

  "permissions": {
    "ipc": ["financeAgent:*", "finance:*"],
    "filesystem": ["$DATA_DIR/finance/"],
    "network": false,
    "shell": false
  }
}
