import { useMemo } from 'react';
import { TrendingUp, Target } from 'lucide-react';
import type { TaskCompletionTrend } from '../../services/analyticsService';

interface TaskCompletionChartProps {
  data: TaskCompletionTrend[];
  expanded?: boolean;
}

export default function TaskCompletionChart({ data, expanded = false }: TaskCompletionChartProps) {
  // Calculate stats
  const stats = useMemo(() => {
    const totalCompleted = data.reduce((sum, d) => sum + d.completed, 0);
    const totalCreated = data.reduce((sum, d) => sum + d.created, 0);
    const avgRate = totalCreated > 0 ? Math.round((totalCompleted / totalCreated) * 100) : 0;
    
    // Trend calculation (last 7 days vs previous 7 days)
    const recent = data.slice(-7);
    const previous = data.slice(-14, -7);
    const recentRate = recent.reduce((sum, d) => sum + d.completionRate, 0) / recent.length;
    const previousRate = previous.length > 0 
      ? previous.reduce((sum, d) => sum + d.completionRate, 0) / previous.length 
      : recentRate;
    const trend = recentRate - previousRate;

    return {
      totalCompleted,
      totalCreated,
      avgRate,
      trend,
      recentRate: Math.round(recentRate),
    };
  }, [data]);

  // Normalize data for chart
  const maxValue = useMemo(() => {
    return Math.max(...data.map(d => Math.max(d.created, d.completed)));
  }, [data]);

  const chartHeight = expanded ? 400 : 200;

  return (
    <div className={`bg-clawd-surface border border-clawd-border rounded-xl p-6 ${expanded ? 'col-span-full' : ''}`}>
      <div className="flex items-center justify-between mb-4">
        <div>
          <h3 className="font-semibold flex items-center gap-2">
            <Target size={18} className="text-clawd-accent" />
            Task Completion Trends
          </h3>
          <p className="text-sm text-clawd-text-dim mt-1">
            Created vs Completed over time
          </p>
        </div>
        
        <div className="text-right">
          <div className="flex items-center gap-2">
            <TrendingUp
              size={16}
              className={stats.trend >= 0 ? 'text-green-400' : 'text-red-400'}
            />
            <span className={`text-sm font-medium ${stats.trend >= 0 ? 'text-green-400' : 'text-red-400'}`}>
              {stats.trend >= 0 ? '+' : ''}{stats.trend.toFixed(1)}%
            </span>
          </div>
          <div className="text-xs text-clawd-text-dim">vs previous period</div>
        </div>
      </div>

      {/* Stats Bar */}
      <div className="grid grid-cols-3 gap-4 mb-6">
        <div className="text-center p-3 bg-clawd-bg rounded-lg">
          <div className="text-2xl font-bold text-blue-400">{stats.totalCreated}</div>
          <div className="text-xs text-clawd-text-dim">Created</div>
        </div>
        <div className="text-center p-3 bg-clawd-bg rounded-lg">
          <div className="text-2xl font-bold text-green-400">{stats.totalCompleted}</div>
          <div className="text-xs text-clawd-text-dim">Completed</div>
        </div>
        <div className="text-center p-3 bg-clawd-bg rounded-lg">
          <div className="text-2xl font-bold text-clawd-accent">{stats.avgRate}%</div>
          <div className="text-xs text-clawd-text-dim">Avg Rate</div>
        </div>
      </div>

      {/* Chart */}
      <div className="relative" style={{ height: chartHeight }}>
        <svg width="100%" height="100%" className="overflow-visible">
          {/* Grid lines */}
          {[0, 0.25, 0.5, 0.75, 1].map((ratio) => (
            <g key={ratio}>
              <line
                x1="0"
                y1={chartHeight * ratio}
                x2="100%"
                y2={chartHeight * ratio}
                stroke="currentColor"
                strokeWidth="1"
                className="text-clawd-border opacity-20"
              />
              <text
                x="0"
                y={chartHeight * ratio - 4}
                fontSize="10"
                fill="currentColor"
                className="text-clawd-text-dim"
              >
                {Math.round(maxValue * (1 - ratio))}
              </text>
            </g>
          ))}

          {/* Data points and lines */}
          {data.length > 0 && (
            <g>
              {/* Created line (blue) */}
              <polyline
                points={data.map((d, i) => {
                  const x = (i / (data.length - 1)) * 100;
                  const y = chartHeight - (d.created / maxValue) * chartHeight;
                  return `${x}%,${y}`;
                }).join(' ')}
                fill="none"
                stroke="#60A5FA"
                strokeWidth="2"
                className="drop-shadow-glow"
              />

              {/* Completed line (green) */}
              <polyline
                points={data.map((d, i) => {
                  const x = (i / (data.length - 1)) * 100;
                  const y = chartHeight - (d.completed / maxValue) * chartHeight;
                  return `${x}%,${y}`;
                }).join(' ')}
                fill="none"
                stroke="#34D399"
                strokeWidth="2"
                className="drop-shadow-glow"
              />

              {/* Completion rate area (subtle) */}
              <defs>
                <linearGradient id="completionGradient" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stopColor="#8B5CF6" stopOpacity="0.3" />
                  <stop offset="100%" stopColor="#8B5CF6" stopOpacity="0.05" />
                </linearGradient>
              </defs>
              <polygon
                points={[
                  ...data.map((d, i) => {
                    const x = (i / (data.length - 1)) * 100;
                    const y = chartHeight - ((d.completionRate / 100) * chartHeight);
                    return `${x}%,${y}`;
                  }),
                  `100%,${chartHeight}`,
                  `0%,${chartHeight}`,
                ].join(' ')}
                fill="url(#completionGradient)"
              />

              {/* Data points */}
              {data.map((d, i) => {
                const x = (i / (data.length - 1)) * 100;
                const yCreated = chartHeight - (d.created / maxValue) * chartHeight;
                const yCompleted = chartHeight - (d.completed / maxValue) * chartHeight;
                
                return (
                  <g key={i}>
                    <circle
                      cx={`${x}%`}
                      cy={yCreated}
                      r="3"
                      fill="#60A5FA"
                      className="hover:r-5 transition-all cursor-pointer"
                    >
                      <title>{`${d.date}: ${d.created} created`}</title>
                    </circle>
                    <circle
                      cx={`${x}%`}
                      cy={yCompleted}
                      r="3"
                      fill="#34D399"
                      className="hover:r-5 transition-all cursor-pointer"
                    >
                      <title>{`${d.date}: ${d.completed} completed (${d.completionRate.toFixed(1)}%)`}</title>
                    </circle>
                  </g>
                );
              })}
            </g>
          )}
        </svg>

        {/* Legend */}
        <div className="absolute top-2 right-2 flex items-center gap-4 text-xs">
          <div className="flex items-center gap-1">
            <div className="w-3 h-3 bg-blue-400 rounded-full" />
            <span className="text-clawd-text-dim">Created</span>
          </div>
          <div className="flex items-center gap-1">
            <div className="w-3 h-3 bg-green-400 rounded-full" />
            <span className="text-clawd-text-dim">Completed</span>
          </div>
          <div className="flex items-center gap-1">
            <div className="w-3 h-3 bg-purple-400 rounded-full opacity-50" />
            <span className="text-clawd-text-dim">Rate</span>
          </div>
        </div>
      </div>

      {/* Date labels */}
      {data.length > 0 && (
        <div className="flex justify-between mt-4 text-xs text-clawd-text-dim">
          <span>{formatDate(data[0].date)}</span>
          <span>{formatDate(data[Math.floor(data.length / 2)].date)}</span>
          <span>{formatDate(data[data.length - 1].date)}</span>
        </div>
      )}
    </div>
  );
}

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
