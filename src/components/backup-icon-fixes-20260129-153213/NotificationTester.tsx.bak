/**
 * NotificationTester Component
 * Development tool for testing system notifications and action buttons
 */

import { useState } from 'react';
import { Bell, CheckCircle, AlertCircle, MessageSquare, Info, X } from 'lucide-react';
import { useNotifications } from '../hooks/useNotifications';

export default function NotificationTester() {
  const {
    preferences,
    recentNotifications,
    testNotification,
    notifyTaskCompleted,
    notifyAgentFailed,
    notifyApprovalNeeded,
    notifyChatMention,
  } = useNotifications();

  const [isOpen, setIsOpen] = useState(false);
  const [customTitle, setCustomTitle] = useState('');
  const [customBody, setCustomBody] = useState('');

  const handleTestBasic = async () => {
    await testNotification();
  };

  const handleTestTaskCompleted = async () => {
    await notifyTaskCompleted('Implement notification system', 'task-1769656174154');
  };

  const handleTestAgentFailed = async () => {
    await notifyAgentFailed(
      'Coder',
      'Fix login bug',
      'Missing API credentials',
      'task-123'
    );
  };

  const handleTestApprovalNeeded = async () => {
    await notifyApprovalNeeded('New tweet: "Just shipped notifications!"', 'approval-456');
  };

  const handleTestChatMention = async () => {
    await notifyChatMention(
      'Kevin',
      'Hey @Froggo, can you check the dashboard?',
      'session-789'
    );
  };

  if (!isOpen) {
    return (
      <button
        onClick={() => setIsOpen(true)}
        className="fixed bottom-4 right-4 z-50 p-3 bg-purple-600 text-white rounded-full shadow-lg hover:bg-purple-700 transition-colors"
        title="Open Notification Tester"
      >
        <Bell size={24} />
      </button>
    );
  }

  return (
    <div className="fixed bottom-4 right-4 z-50 w-96 bg-clawd-bg border border-clawd-border rounded-xl shadow-2xl overflow-hidden">
      {/* Header */}
      <div className="p-4 bg-purple-600 text-white flex items-center justify-between">
        <div className="flex items-center gap-2">
          <Bell size={20} />
          <h3 className="font-semibold">Notification Tester</h3>
        </div>
        <button
          onClick={() => setIsOpen(false)}
          className="p-1 hover:bg-purple-700 rounded transition-colors"
        >
          <X size={18} />
        </button>
      </div>

      {/* Content */}
      <div className="p-4 space-y-4 max-h-[600px] overflow-y-auto">
        {/* Current Preferences */}
        {preferences && (
          <div className="bg-clawd-border/50 rounded-lg p-3 text-sm">
            <div className="font-medium mb-2">Current Settings</div>
            <div className="space-y-1 text-clawd-text-dim">
              <div>Enabled: {preferences.enabled ? '✅' : '❌'}</div>
              <div>Task Completions: {preferences.taskCompletions ? '✅' : '❌'}</div>
              <div>Agent Failures: {preferences.agentFailures ? '✅' : '❌'}</div>
              <div>Approval Requests: {preferences.approvalRequests ? '✅' : '❌'}</div>
              <div>Chat Mentions: {preferences.chatMentions ? '✅' : '❌'}</div>
              <div>Sound: {preferences.sound ? '✅' : '❌'}</div>
              <div>Show Previews: {preferences.showPreviews ? '✅' : '❌'}</div>
            </div>
          </div>
        )}

        {/* Test Buttons */}
        <div className="space-y-2">
          <div className="font-medium text-sm text-clawd-text-dim mb-2">Quick Tests</div>
          
          <button
            onClick={handleTestBasic}
            className="w-full p-3 bg-clawd-accent text-white rounded-lg hover:bg-clawd-accent/80 transition-colors flex items-center gap-2"
          >
            <Info size={18} />
            Basic Test Notification
          </button>

          <button
            onClick={handleTestTaskCompleted}
            className="w-full p-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors flex items-center gap-2"
          >
            <CheckCircle size={18} />
            Task Completed
          </button>

          <button
            onClick={handleTestAgentFailed}
            className="w-full p-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center gap-2"
          >
            <AlertCircle size={18} />
            Agent Failure
          </button>

          <button
            onClick={handleTestApprovalNeeded}
            className="w-full p-3 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition-colors flex items-center gap-2"
          >
            <Bell size={18} />
            Approval Needed
          </button>

          <button
            onClick={handleTestChatMention}
            className="w-full p-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center gap-2"
          >
            <MessageSquare size={18} />
            Chat Mention
          </button>
        </div>

        {/* Recent Notifications */}
        {recentNotifications.length > 0 && (
          <div className="space-y-2">
            <div className="font-medium text-sm text-clawd-text-dim">
              Recent ({recentNotifications.length})
            </div>
            <div className="space-y-2 max-h-48 overflow-y-auto">
              {recentNotifications.slice(0, 5).map((notif, idx) => (
                <div
                  key={idx}
                  className="bg-clawd-border/30 rounded p-2 text-sm"
                >
                  <div className="font-medium">{notif.title}</div>
                  <div className="text-clawd-text-dim text-xs mt-1">
                    {notif.body}
                  </div>
                  <div className="text-clawd-text-dim text-xs mt-1">
                    {new Date(notif.timestamp).toLocaleTimeString()}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Help Text */}
        <div className="text-xs text-clawd-text-dim bg-clawd-border/30 rounded p-3">
          <div className="font-medium mb-1">💡 Testing Tips</div>
          <ul className="space-y-1 list-disc list-inside">
            <li>Click notifications to test navigation</li>
            <li>Action buttons work on macOS</li>
            <li>Check system notification settings if not appearing</li>
            <li>Settings → Global Notification Settings to configure</li>
          </ul>
        </div>
      </div>
    </div>
  );
}
