import { useMemo } from 'react';
import { Users, Award, Clock, TrendingUp } from 'lucide-react';
import type { AgentUtilization } from '../../services/analyticsService';

interface AgentUtilizationChartProps {
  data: AgentUtilization[];
  expanded?: boolean;
}

export default function AgentUtilizationChart({ data, expanded = false }: AgentUtilizationChartProps) {
  // Sort by completion count
  const sortedData = useMemo(() => {
    return [...data].sort((a, b) => b.tasksCompleted - a.tasksCompleted);
  }, [data]);

  const maxTasks = useMemo(() => {
    return Math.max(...data.map(a => a.tasksAssigned), 1);
  }, [data]);

  const topPerformer = sortedData[0];
  const totalHours = data.reduce((sum, a) => sum + a.totalTimeSpent, 0);
  const avgCompletionRate = data.length > 0
    ? Math.round(data.reduce((sum, a) => sum + a.completionRate, 0) / data.length)
    : 0;

  const getAgentEmoji = (agentId: string): string => {
    const emojiMap: Record<string, string> = {
      coder: '💻',
      researcher: '🔍',
      writer: '✍️',
      chief: '👨‍💻',
      main: '🐸',
      froggo: '🐸',
    };
    return emojiMap[agentId.toLowerCase()] || '🤖';
  };

  return (
    <div className={`bg-clawd-surface border border-clawd-border rounded-xl p-6 ${expanded ? 'col-span-full' : ''}`}>
      <div className="flex items-center justify-between mb-4">
        <div>
          <h3 className="font-semibold flex items-center gap-2">
            <Users size={18} className="text-clawd-accent" />
            Agent Performance
          </h3>
          <p className="text-sm text-clawd-text-dim mt-1">
            Task completion and time tracking
          </p>
        </div>
        
        {topPerformer && (
          <div className="text-right">
            <div className="flex items-center gap-2">
              <Award size={16} className="text-yellow-400" />
              <span className="text-sm font-medium">{getAgentEmoji(topPerformer.agentId)} {topPerformer.agentName}</span>
            </div>
            <div className="text-xs text-clawd-text-dim">Top Performer</div>
          </div>
        )}
      </div>

      {/* Summary Stats */}
      <div className="grid grid-cols-3 gap-4 mb-6">
        <div className="text-center p-3 bg-clawd-bg rounded-lg">
          <div className="text-2xl font-bold text-purple-400">{data.length}</div>
          <div className="text-xs text-clawd-text-dim">Active Agents</div>
        </div>
        <div className="text-center p-3 bg-clawd-bg rounded-lg">
          <div className="text-2xl font-bold text-green-400">{avgCompletionRate}%</div>
          <div className="text-xs text-clawd-text-dim">Avg Rate</div>
        </div>
        <div className="text-center p-3 bg-clawd-bg rounded-lg">
          <div className="text-2xl font-bold text-orange-400">{totalHours.toFixed(0)}h</div>
          <div className="text-xs text-clawd-text-dim">Total Time</div>
        </div>
      </div>

      {/* Agent Bars */}
      <div className="space-y-4">
        {sortedData.map((agent) => (
          <div key={agent.agentId} className="space-y-2">
            <div className="flex items-center justify-between text-sm">
              <div className="flex items-center gap-2">
                <span className="text-lg">{getAgentEmoji(agent.agentId)}</span>
                <span className="font-medium">{agent.agentName}</span>
                <span className="text-clawd-text-dim">
                  ({agent.tasksCompleted}/{agent.tasksAssigned})
                </span>
              </div>
              <div className="flex items-center gap-4 text-xs">
                <div className="flex items-center gap-1">
                  <TrendingUp size={12} className="text-green-400" />
                  <span className={`font-medium ${
                    agent.completionRate >= 75 ? 'text-green-400' :
                    agent.completionRate >= 50 ? 'text-yellow-400' :
                    'text-red-400'
                  }`}>
                    {agent.completionRate}%
                  </span>
                </div>
                <div className="flex items-center gap-1 text-clawd-text-dim">
                  <Clock size={12} />
                  <span>{agent.totalTimeSpent.toFixed(1)}h</span>
                </div>
              </div>
            </div>

            {/* Progress bars */}
            <div className="relative h-8 bg-clawd-bg rounded-lg overflow-hidden">
              {/* Completed */}
              <div
                className="absolute inset-y-0 left-0 bg-gradient-to-r from-green-500 to-green-400 transition-all"
                style={{
                  width: `${(agent.tasksCompleted / maxTasks) * 100}%`,
                }}
              />
              {/* In Progress */}
              <div
                className="absolute inset-y-0 bg-gradient-to-r from-blue-500 to-blue-400 transition-all opacity-70"
                style={{
                  left: `${(agent.tasksCompleted / maxTasks) * 100}%`,
                  width: `${(agent.tasksInProgress / maxTasks) * 100}%`,
                }}
              />
              {/* Total assigned (background indicator) */}
              <div
                className="absolute inset-y-0 left-0 border-2 border-clawd-border rounded-lg"
                style={{
                  width: `${(agent.tasksAssigned / maxTasks) * 100}%`,
                }}
              />
              
              {/* Labels */}
              <div className="absolute inset-0 flex items-center px-3 text-xs font-medium text-white">
                <span className="drop-shadow-lg">
                  {agent.tasksCompleted} completed
                </span>
                {agent.tasksInProgress > 0 && (
                  <span className="ml-2 drop-shadow-lg opacity-90">
                    + {agent.tasksInProgress} in progress
                  </span>
                )}
              </div>
            </div>

            {/* Detailed stats (expanded view) */}
            {expanded && (
              <div className="grid grid-cols-3 gap-2 text-xs pt-2">
                <div className="p-2 bg-clawd-bg rounded">
                  <div className="text-clawd-text-dim">Avg Completion Time</div>
                  <div className="font-medium text-blue-400">
                    {agent.avgCompletionTime.toFixed(1)}h
                  </div>
                </div>
                <div className="p-2 bg-clawd-bg rounded">
                  <div className="text-clawd-text-dim">Tasks/Hour</div>
                  <div className="font-medium text-purple-400">
                    {agent.totalTimeSpent > 0 
                      ? (agent.tasksCompleted / agent.totalTimeSpent).toFixed(2)
                      : '0.00'}
                  </div>
                </div>
                <div className="p-2 bg-clawd-bg rounded">
                  <div className="text-clawd-text-dim">Utilization</div>
                  <div className={`font-medium ${
                    agent.tasksInProgress > 2 ? 'text-red-400' :
                    agent.tasksInProgress > 0 ? 'text-yellow-400' :
                    'text-green-400'
                  }`}>
                    {agent.tasksInProgress > 2 ? 'High' :
                     agent.tasksInProgress > 0 ? 'Medium' :
                     'Available'}
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Legend */}
      <div className="flex items-center justify-center gap-6 mt-6 pt-4 border-t border-clawd-border text-xs">
        <div className="flex items-center gap-2">
          <div className="w-4 h-2 bg-gradient-to-r from-green-500 to-green-400 rounded" />
          <span className="text-clawd-text-dim">Completed</span>
        </div>
        <div className="flex items-center gap-2">
          <div className="w-4 h-2 bg-gradient-to-r from-blue-500 to-blue-400 rounded opacity-70" />
          <span className="text-clawd-text-dim">In Progress</span>
        </div>
        <div className="flex items-center gap-2">
          <div className="w-4 h-2 border-2 border-clawd-border rounded" />
          <span className="text-clawd-text-dim">Total Assigned</span>
        </div>
      </div>
    </div>
  );
}
