# Froggo Gateway — Environment Variables

# ── Clerk Auth ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Fly.io Machines API ──────────────────────────────────────────────────────
FLY_API_TOKEN=...
FLY_APP_NAME=froggo-mission-control
FLY_ORG=personal

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of workspace secrets
ENCRYPTION_KEY=...

# ── Vector DB (shared knowledge) ──────────────────────────────────────────────
# TURBOPUFFER_API_KEY=...
# Or: PINECONE_API_KEY=...

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=...
